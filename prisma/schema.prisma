generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ModelAsset {
  id        String      @id
  fileName  String
  fileUrl   String
  kind      AssetKind
  status    AssetStatus
  createdAt DateTime

  hallTemplateGlbOf       HallTemplate[] @relation("HallTemplateGlb")
  hallTemplateThumbnailOf HallTemplate[] @relation("HallTemplateThumbnail")
  hallTemplateBlendOf     HallTemplate[] @relation("HallTemplateBlend")

  boothTemplateGlbOf       BoothTemplate[] @relation("BoothTemplateGlb")
  boothTemplateThumbnailOf BoothTemplate[] @relation("BoothTemplateThumbnail")
  boothTemplateBlendOf     BoothTemplate[] @relation("BoothTemplateBlend")
}

model HallTemplate {
  id               String   @id
  name             String
  isPublic         Boolean
  isActive         Boolean
  updatedBy        String
  updatedAt        DateTime

  sourceBlendAssetId String?
  sourceBlendAsset   ModelAsset? @relation("HallTemplateBlend", fields: [sourceBlendAssetId], references: [id], onDelete: SetNull)

  renderGlbAssetId String
  renderGlbAsset   ModelAsset @relation("HallTemplateGlb", fields: [renderGlbAssetId], references: [id], onDelete: Restrict)

  thumbnailAssetId String
  thumbnailAsset   ModelAsset @relation("HallTemplateThumbnail", fields: [thumbnailAssetId], references: [id], onDelete: Restrict)

  translations HallTemplateTranslation[]
  slots        HallTemplateSlot[]
  usage        HallTemplateUsage?

  @@index([renderGlbAssetId])
  @@index([thumbnailAssetId])
}

model HallTemplateTranslation {
  id           String @id
  hallTemplateId String
  languageCode String
  name         String

  hallTemplate HallTemplate @relation(fields: [hallTemplateId], references: [id], onDelete: Cascade)

  @@unique([hallTemplateId, languageCode])
  @@index([languageCode])
}

model HallTemplateSlot {
  id             String @id
  hallTemplateId String
  slotCode       String
  name           String

  posX   Float
  posY   Float
  posZ   Float
  rotX   Float
  rotY   Float
  rotZ   Float
  scaleX Float
  scaleY Float
  scaleZ Float

  width  Float
  height Float
  depth  Float

  metadata Json

  hallTemplate HallTemplate @relation(fields: [hallTemplateId], references: [id], onDelete: Cascade)
  usage        HallSlotUsage?

  @@unique([hallTemplateId, slotCode])
  @@index([hallTemplateId])
}

model HallTemplateUsage {
  hallTemplateId     String @id
  upcomingExpoCount  Int
  liveExpoCount      Int
  archivedExpoCount  Int

  hallTemplate HallTemplate @relation(fields: [hallTemplateId], references: [id], onDelete: Cascade)
}

model HallSlotUsage {
  slotId            String @id
  upcomingExpoCount Int
  liveExpoCount     Int

  slot HallTemplateSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
}

model BoothType {
  id   String @id
  name String

  boothTemplates BoothTemplate[]
}

model BoothTemplate {
  id          String @id
  name        String
  description String
  isPublic    Boolean
  isActive    Boolean
  updatedBy   String
  updatedAt   DateTime

  boothTypeId String
  boothType   BoothType @relation(fields: [boothTypeId], references: [id], onDelete: Restrict)

  sourceBlendAssetId String?
  sourceBlendAsset   ModelAsset? @relation("BoothTemplateBlend", fields: [sourceBlendAssetId], references: [id], onDelete: SetNull)

  renderGlbAssetId String
  renderGlbAsset   ModelAsset @relation("BoothTemplateGlb", fields: [renderGlbAssetId], references: [id], onDelete: Restrict)

  thumbnailAssetId String
  thumbnailAsset   ModelAsset @relation("BoothTemplateThumbnail", fields: [thumbnailAssetId], references: [id], onDelete: Restrict)

  translations BoothTemplateTranslation[]
  usage        BoothTemplateUsage?

  @@index([boothTypeId])
}

model BoothTemplateTranslation {
  id             String @id
  boothTemplateId String
  languageCode   String
  name           String

  boothTemplate BoothTemplate @relation(fields: [boothTemplateId], references: [id], onDelete: Cascade)

  @@unique([boothTemplateId, languageCode])
  @@index([languageCode])
}

model BoothTemplateUsage {
  boothTemplateId       String @id
  upcomingExpoBoothCount Int
  liveExpoBoothCount     Int
  archivedExpoBoothCount Int

  boothTemplate BoothTemplate @relation(fields: [boothTemplateId], references: [id], onDelete: Cascade)
}

enum AssetStatus {
  pending
  processing
  ready
  failed
}

enum AssetKind {
  blend
  glb
  thumbnail
}

